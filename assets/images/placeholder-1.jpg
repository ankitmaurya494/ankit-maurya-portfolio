<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF6B6B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FF8E72;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#grad1)"/>
  <circle cx="400" cy="300" r="150" fill="rgba(255,255,255,0.3)"/>
  <circle cx="250" cy="200" r="80" fill="rgba(255,255,255,0.2)"/>
  <circle cx="550" cy="450" r="120" fill="rgba(255,255,255,0.15)"/>
  <text x="400" y="300" font-size="48" text-anchor="middle" font-weight="bold" fill="white" opacity="0.7">Photography</text>
</svg>